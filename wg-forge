#!/bin/bash
# ─────────────────────────────────────────────
#  wg-forge - WireGuard Client Manager
#  https://github.com/Arsh1a/wg-forge
# ─────────────────────────────────────────────

VERSION="0.4.4"
CONFIG_FILE="/etc/wg-forge/config.conf"

# Helpers

bytes_to_human() {
    local B=${1:-0}
    if   [ "$B" -ge 1073741824 ]; then printf "%.2fGB" "$(echo "scale=2; $B/1073741824" | bc)"
    elif [ "$B" -ge 1048576 ];    then printf "%.2fMB" "$(echo "scale=2; $B/1048576"    | bc)"
    elif [ "$B" -ge 1024 ];       then printf "%.2fKB" "$(echo "scale=2; $B/1024"       | bc)"
    else echo "${B}B"
    fi
}

human_to_bytes() {
    local N U
    N=$(echo "$1" | grep -oE '[0-9]+(\.[0-9]+)?')
    U=$(echo "$1" | grep -oE '[A-Za-z]+' | tr '[:lower:]' '[:upper:]')
    case "$U" in
        GB) printf "%.0f" "$(echo "$N * 1073741824" | bc)" ;;
        MB) printf "%.0f" "$(echo "$N * 1048576"    | bc)" ;;
        KB) printf "%.0f" "$(echo "$N * 1024"       | bc)" ;;
        *)  printf "%.0f" "$N" ;;
    esac
}

next_ip() {
    local last
    last=$(grep -v "^#" "$CLIENTS_FILE" | awk -F: '{print $3}' | sort -t. -k4 -n | tail -1 | cut -d/ -f1)
    if [ -z "$last" ]; then
        echo "${WG_SUBNET}.3"
    else
        local base num
        base=$(echo "$last" | cut -d. -f1-3)
        num=$(echo  "$last" | cut -d. -f4)
        echo "$base.$((num+1))"
    fi
}

update_lifetime() {
    local NAME=$1 DELTA=${2:-0}
    grep -q "^$NAME:" "$TOTAL_FILE" || echo "$NAME:0" >> "$TOTAL_FILE"
    [ "$DELTA" -le 0 ] && return
    local OLD NEW
    OLD=$(grep "^$NAME:" "$TOTAL_FILE" | cut -d: -f2)
    NEW=$((OLD + DELTA))
    awk -F: -v n="$NAME" -v v="$NEW" \
        'BEGIN{OFS=":"} $1==n{$2=v} {print}' \
        "$TOTAL_FILE" > /tmp/.wgf_tot && mv /tmp/.wgf_tot "$TOTAL_FILE"
}

lim_set_field() {
    awk -F: -v n="$1" -v f="$2" -v v="$3" \
        'BEGIN{OFS=":"} $1==n{$f=v} {print}' \
        "$LIMITS_FILE" > /tmp/.wgf_lim && mv /tmp/.wgf_lim "$LIMITS_FILE"
}

handshake_age() {
    local HS=$1
    [ "$HS" = "0" ] && echo "never" && return
    local D=$(( $(date +%s) - HS ))
    if   [ $D -lt 60 ];   then echo "${D}s ago"
    elif [ $D -lt 3600 ]; then echo "$((D/60))m ago"
    else                       echo "$((D/3600))h ago"
    fi
}

wg_peer_info() { wg show "$WG_INTERFACE" dump | grep "$1"; }

print_qr() {
    local CONF=$1
    if command -v qrencode >/dev/null 2>&1; then
        echo ""
        echo "──── QR Code ───────────────────────────"
        echo "$CONF" | qrencode -t ansiutf8
        echo "────────────────────────────────────────"
    fi
}

# Render a client .conf. IP may be given with or without a /32 suffix.
# DNS falls back to 8.8.8.8 for configs created before WG_DNS existed.
# AllowedIPs falls back to 0.0.0.0/0 (full tunnel) for configs created before
# WG_ALLOWED_IPS existed; set it to specific subnets for a split tunnel.
client_config() {
    local PRIV=$1 IP=$2
    cat <<EOF
[Interface]
PrivateKey = $PRIV
Address = ${IP%/32}/32
DNS = ${WG_DNS:-8.8.8.8}

[Peer]
PublicKey = $VPS_PUBKEY
Endpoint = $VPS_ENDPOINT
AllowedIPs = ${WG_ALLOWED_IPS:-0.0.0.0/0}
PersistentKeepalive = 25
EOF
}

# Commands

install_wg_deps() {
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update -qq && apt-get install -y wireguard-tools perl bc curl
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y wireguard-tools perl bc curl iptables-nft
    elif command -v yum >/dev/null 2>&1; then
        yum install -y wireguard-tools perl bc curl iptables-nft
    elif command -v pacman >/dev/null 2>&1; then
        pacman -Sy --noconfirm wireguard-tools perl bc curl
    else
        echo "✗ Unsupported package manager — install wireguard-tools, perl, bc, curl manually"
        exit 1
    fi
}

cmd_setup() {
    echo "╔══════════════════════════════╗"
    echo "║     wg-forge  Setup          ║"
    echo "╚══════════════════════════════╝"
    echo ""

    [ "$EUID" -ne 0 ] && echo "✗ Run as root" && exit 1

    # Install WireGuard if missing
    if ! command -v wg >/dev/null 2>&1; then
        echo "WireGuard not found — installing..."
        install_wg_deps
        echo ""
    fi

    mkdir -p /etc/wg-forge /etc/wireguard/keys
    chmod 700 /etc/wireguard/keys

    # Collect settings
    read -rp "WireGuard interface         [wg0]:     " WG_IF;   WG_IF=${WG_IF:-wg0}
    read -rp "WireGuard listen port       [51820]:   " WG_PORT; WG_PORT=${WG_PORT:-51820}
    read -rp "VPN subnet (3 octets)       [10.99.0]: " SUBNET;  SUBNET=${SUBNET:-10.99.0}

    # Detect public IP
    local DETECTED_IP
    DETECTED_IP=$(curl -fsSL --max-time 5 https://api.ipify.org 2>/dev/null || true)
    read -rp "Server public IP            [${DETECTED_IP:-?}]: " VPS_IP
    VPS_IP=${VPS_IP:-$DETECTED_IP}
    [ -z "$VPS_IP" ] && echo "✗ Public IP is required" && exit 1

    # Detect default network interface for NAT
    local PUB_IFACE
    PUB_IFACE=$(ip route show default | awk '{print $5}' | head -1)
    read -rp "Public network interface    [${PUB_IFACE:-eth0}]: " NET_IF
    NET_IF=${NET_IF:-${PUB_IFACE:-eth0}}

    # DNS pushed to clients (comma-separate for multiple, e.g. 1.1.1.1, 1.0.0.1)
    read -rp "Client DNS server(s)        [8.8.8.8]: " WG_DNS; WG_DNS=${WG_DNS:-8.8.8.8}

    # Client AllowedIPs: 0.0.0.0/0 routes all traffic through the VPN (full
    # tunnel). Narrow it to specific subnets for a split tunnel, e.g. 10.0.0.0/8.
    read -rp "Client routes (AllowedIPs)  [0.0.0.0/0]: " WG_ALLOWED_IPS
    WG_ALLOWED_IPS=${WG_ALLOWED_IPS:-0.0.0.0/0}

    # Generate server keypair
    local SERVER_PRIV SERVER_PUB
    SERVER_PRIV=$(wg genkey)
    SERVER_PUB=$(echo "$SERVER_PRIV" | wg pubkey)
    printf "%s" "$SERVER_PRIV" > /etc/wireguard/server.key
    chmod 600 /etc/wireguard/server.key

    # Write wg0.conf
    local WG_CONF="/etc/wireguard/${WG_IF}.conf"
    cat > "$WG_CONF" <<EOF
[Interface]
Address = ${SUBNET}.1/24
ListenPort = $WG_PORT
PrivateKey = $SERVER_PRIV
PostUp   = iptables -A FORWARD -i $WG_IF -j ACCEPT; iptables -t nat -A POSTROUTING -o $NET_IF -j MASQUERADE
PostDown = iptables -D FORWARD -i $WG_IF -j ACCEPT; iptables -t nat -D POSTROUTING -o $NET_IF -j MASQUERADE
EOF
    chmod 600 "$WG_CONF"

    # Enable IP forwarding
    if ! grep -q "^net.ipv4.ip_forward=1" /etc/sysctl.conf 2>/dev/null; then
        echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf
    fi
    sysctl -qw net.ipv4.ip_forward=1

    # Start WireGuard
    systemctl enable --now "wg-quick@${WG_IF}"

    # Save wg-forge config
    cat > "$CONFIG_FILE" <<EOF
# wg-forge configuration
WG_INTERFACE="$WG_IF"
VPS_PUBKEY="$SERVER_PUB"
VPS_ENDPOINT="$VPS_IP:$WG_PORT"
WG_SUBNET="$SUBNET"
WG_DNS="$WG_DNS"
WG_ALLOWED_IPS="$WG_ALLOWED_IPS"
WG_CONF="$WG_CONF"
CLIENTS_FILE="/etc/wireguard/clients.conf"
LIMITS_FILE="/etc/wireguard/limits.conf"
TOTAL_FILE="/etc/wireguard/total_bandwidth.conf"
EOF

    for f in "/etc/wireguard/clients.conf" \
              "/etc/wireguard/limits.conf" \
              "/etc/wireguard/total_bandwidth.conf"; do
        [ -f "$f" ] || echo "# wg-forge data" > "$f"
    done

    echo ""
    echo "✓ WireGuard interface $WG_IF is up"
    echo "✓ Server public key:  $SERVER_PUB"
    echo "✓ Endpoint:           $VPS_IP:$WG_PORT"
    echo "✓ VPN subnet:         ${SUBNET}.0/24"

    # Web UI setup
    echo ""
    read -rp "Set up web dashboard? [y/N]: " WANT_WEB
    if [[ "$WANT_WEB" =~ ^[Yy]$ ]]; then
        cmd_setup_web
    else
        echo ""
        echo "  Run 'wg-forge add <name>' to create your first client."
    fi
}

cmd_setup_web() {
    echo ""
    echo "── Web Dashboard Setup ─────────────────"

    read -rp "Web UI port                 [8080]: " WEB_PORT; WEB_PORT=${WEB_PORT:-8080}
    read -rp "Admin username              [admin]: " WEB_USER; WEB_USER=${WEB_USER:-admin}
    read -rsp "Admin password: " WEB_PASS; echo
    read -rsp "Confirm password: " WEB_PASS2; echo
    [ "$WEB_PASS" != "$WEB_PASS2" ] && echo "✗ Passwords do not match" && exit 1
    [ -z "$WEB_PASS" ] && echo "✗ Password cannot be empty" && exit 1

    read -rp "Use domain + HTTPS (nginx)? [y/N]: " WANT_HTTPS
    local WEB_DOMAIN=""
    if [[ "$WANT_HTTPS" =~ ^[Yy]$ ]]; then
        read -rp "Domain name (e.g. vpn.example.com): " WEB_DOMAIN
        [ -z "$WEB_DOMAIN" ] && echo "✗ Domain is required for HTTPS" && exit 1
    fi

    # Generate secret path slug (20+ random chars)
    local SECRET_SLUG
    SECRET_SLUG=$(openssl rand -base64 18 | tr -dc 'a-z0-9' | head -c 22)

    # Hash password: salt:sha256(salt+pass)
    local WEB_SALT WEB_HASH
    WEB_SALT=$(openssl rand -hex 16)
    WEB_HASH=$(echo -n "${WEB_SALT}${WEB_PASS}" | sha256sum | awk '{print $1}')

    # Determine origin for CSRF
    local ORIGIN
    if [[ "$WANT_HTTPS" =~ ^[Yy]$ ]]; then
        ORIGIN="https://$WEB_DOMAIN"
    else
        local PUBLIC_IP
        PUBLIC_IP=$(curl -fsSL --max-time 5 https://api.ipify.org 2>/dev/null || echo "localhost")
        ORIGIN="http://${PUBLIC_IP}:${WEB_PORT}"
    fi

    cat > /etc/wg-forge/web.conf <<EOF
WEB_PORT="$WEB_PORT"
WEB_USER="$WEB_USER"
WEB_PASS_HASH="${WEB_SALT}:${WEB_HASH}"
WEB_DOMAIN="$WEB_DOMAIN"
PORT="$WEB_PORT"
ORIGIN="$ORIGIN"
SECRET_PATH="$SECRET_SLUG"
EOF
    chmod 600 /etc/wg-forge/web.conf

    # Install Node.js if missing
    if ! command -v node >/dev/null 2>&1; then
        echo "Installing Node.js..."
        NODE_VERSION="20.14.0"
        curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.gz" \
            | tar -xz -C /usr/local --strip-components=1
        echo "✓ Node.js $(node -v) installed"
    fi

    # Build web app from source downloaded by installer
    if [ ! -d /opt/wg-forge-web ]; then
        echo "✗ Web source not found at /opt/wg-forge-web — re-run the installer"
        exit 1
    fi

    echo "Building web dashboard..."
    cd /opt/wg-forge-web && npm install --silent && npm run build || {
        echo "✗ Failed to build web dashboard"
        exit 1
    }
    echo "✓ Web dashboard built"

    # Enable web service
    systemctl daemon-reload
    systemctl enable --now wg-forge-web
    echo "✓ Web dashboard started on port $WEB_PORT"

    # Open firewall port if ufw is active and no HTTPS (nginx handles 80/443)
    if ! [[ "$WANT_HTTPS" =~ ^[Yy]$ ]] && command -v ufw >/dev/null 2>&1 && ufw status | grep -q "Status: active"; then
        ufw allow "$WEB_PORT/tcp" >/dev/null
        echo "✓ ufw: port $WEB_PORT opened"
    fi

    # Setup nginx + SSL if requested
    if [[ "$WANT_HTTPS" =~ ^[Yy]$ ]]; then
        cmd_setup_nginx "$WEB_DOMAIN" "$WEB_PORT"
    fi

    cmd_web
    echo "  Run 'wg-forge add <name>' to create your first client."
}

install_pkgs() {
    if command -v apt-get >/dev/null 2>&1; then
        apt-get install -y "$@"
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y "$@"
    elif command -v yum >/dev/null 2>&1; then
        yum install -y "$@"
    elif command -v pacman >/dev/null 2>&1; then
        pacman -Sy --noconfirm "$@"
    else
        echo "✗ Unsupported package manager — install manually: $*"
        exit 1
    fi
}

cmd_setup_nginx() {
    local DOMAIN=$1 PORT=$2

    if ! command -v nginx >/dev/null 2>&1; then
        echo "Installing nginx..."
        install_pkgs nginx
    fi
    if ! command -v certbot >/dev/null 2>&1; then
        echo "Installing certbot..."
        install_pkgs certbot python3-certbot-nginx
    fi

    cat > "/etc/nginx/sites-available/wg-forge" <<EOF
server {
    listen 80;
    server_name $DOMAIN;

    location / {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
    }
}
EOF

    ln -sf /etc/nginx/sites-available/wg-forge /etc/nginx/sites-enabled/wg-forge
    nginx -t && systemctl reload nginx

    certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos --email "admin@$DOMAIN" --redirect
    echo "✓ HTTPS configured for $DOMAIN"
}

cmd_add() {
    local NAME=$1 LIMIT=$2
    [ -z "$NAME" ] && echo "Usage: wg-forge add <n> [limit e.g. 10GB]" && exit 1

    if ! echo "$NAME" | grep -qE '^[a-zA-Z0-9._-]+$'; then
        echo "✗ Invalid name '$NAME' - only letters, digits, '.', '-', '_' allowed"
        exit 1
    fi

    local SUFFIX FULLNAME
    SUFFIX=$(tr -dc 'a-z0-9' < /dev/urandom | head -c 5)
    FULLNAME="${NAME}-${SUFFIX}"

    grep -q "^$FULLNAME:" "$CLIENTS_FILE" && echo "✗ Name collision - try again" && exit 1

    local PRIV PUB IP
    PRIV=$(wg genkey)
    PUB=$(echo "$PRIV" | wg pubkey)
    IP=$(next_ip)

    mkdir -p /etc/wireguard/keys
    printf "%s" "$PRIV" > "/etc/wireguard/keys/${FULLNAME}.key"
    chmod 600 "/etc/wireguard/keys/${FULLNAME}.key"

    if ! wg set "$WG_INTERFACE" peer "$PUB" allowed-ips "$IP/32" 2>/dev/null; then
        rm -f "/etc/wireguard/keys/${FULLNAME}.key"
        echo "✗ WireGuard rejected peer - is $WG_INTERFACE up?"
        exit 1
    fi

    echo "$FULLNAME:$PUB:$IP/32" >> "$CLIENTS_FILE"
    printf "\n[Peer]\n# %s\nPublicKey = %s\nAllowedIPs = %s/32\n" \
        "$FULLNAME" "$PUB" "$IP" >> "$WG_CONF"

    local LIMIT_BYTES=0
    [ -n "$LIMIT" ] && LIMIT_BYTES=$(human_to_bytes "$LIMIT")
    echo "$FULLNAME:$LIMIT_BYTES:0:active" >> "$LIMITS_FILE"
    grep -q "^$FULLNAME:" "$TOTAL_FILE" || echo "$FULLNAME:0" >> "$TOTAL_FILE"

    if [ "$LIMIT_BYTES" -gt 0 ]; then
        echo "✓ Client '$FULLNAME' created  [limit: $LIMIT]"
    else
        echo "✓ Client '$FULLNAME' created  [no limit]"
    fi

    echo ""
    local CLIENT_CONF
    CLIENT_CONF=$(client_config "$PRIV" "$IP")
    echo "──── Config ────────────────────────────"
    echo "$CLIENT_CONF"
    echo "────────────────────────────────────────"
    print_qr "$CLIENT_CONF"
}

cmd_remove() {
    local NAME=$1
    [ -z "$NAME" ] && echo "Usage: wg-forge remove <n>" && exit 1

    local LINE
    LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
    [ -z "$LINE" ] && echo "✗ Client '$NAME' not found" && exit 1

    local PUB INFO RX TX
    PUB=$(echo "$LINE" | cut -d: -f2)
    INFO=$(wg_peer_info "$PUB")
    if [ -n "$INFO" ]; then
        RX=$(echo "$INFO" | awk '{print $6}')
        TX=$(echo "$INFO" | awk '{print $7}')
        update_lifetime "$NAME" $((RX + TX))
    fi

    wg set "$WG_INTERFACE" peer "$PUB" remove 2>/dev/null
    sed -i "/^$NAME:/d" "$CLIENTS_FILE"
    sed -i "/^$NAME:/d" "$LIMITS_FILE"

    perl -i -0pe "s/\n\[Peer\]\n# $NAME\nPublicKey = [^\n]+\nAllowedIPs = [^\n]+//g" "$WG_CONF"
    perl -i -0pe 's/\[Peer\]\n(?=\[Peer\])//g' "$WG_CONF"
    perl -i -0pe 's/\[Peer\]\n(?=\[Peer\])//g' "$WG_CONF"

    rm -f "/etc/wireguard/keys/${NAME}.key"
    echo "✓ Client '$NAME' removed  (bandwidth history preserved)"
}

cmd_show() {
    local NAME=$1
    [ -z "$NAME" ] && echo "Usage: wg-forge show <n>" && exit 1

    local LINE
    LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
    [ -z "$LINE" ] && echo "✗ Client '$NAME' not found" && exit 1

    local PUB IP LIM_LINE LIMIT_BYTES STATUS LIFETIME
    PUB=$(echo "$LINE"             | cut -d: -f2)
    IP=$(echo "$LINE"              | cut -d: -f3)
    LIM_LINE=$(grep "^$NAME:" "$LIMITS_FILE")
    LIMIT_BYTES=$(echo "$LIM_LINE" | cut -d: -f2)
    STATUS=$(echo "$LIM_LINE"      | cut -d: -f4)
    LIFETIME=$(grep "^$NAME:" "$TOTAL_FILE" | cut -d: -f2)

    echo "╔══════════════════════════════════════╗"
    printf  "║  Client: %-28s║\n" "$NAME"
    echo   "╚══════════════════════════════════════╝"
    printf "  %-18s %s\n" "IP:"            "${IP%/32}"
    printf "  %-18s %s\n" "Status:"        "${STATUS:-active}"
    if [ "${LIMIT_BYTES:-0}" -gt 0 ]; then
        printf "  %-18s %s\n" "Limit:"     "$(bytes_to_human "$LIMIT_BYTES")"
    else
        printf "  %-18s %s\n" "Limit:"     "unlimited"
    fi
    printf "  %-18s %s\n" "Lifetime used:" "$(bytes_to_human "${LIFETIME:-0}")"
    echo ""

    local INFO HS RX TX TOTAL
    INFO=$(wg_peer_info "$PUB")
    if [ -n "$INFO" ]; then
        HS=$(echo "$INFO"   | awk '{print $5}')
        RX=$(echo "$INFO"   | awk '{print $6}')
        TX=$(echo "$INFO"   | awk '{print $7}')
        TOTAL=$((RX + TX))
        printf "  %-18s %s\n" "Last handshake:" "$(handshake_age "$HS")"
        printf "  %-18s %s\n" "Downloaded:"     "$(bytes_to_human "$RX")"
        printf "  %-18s %s\n" "Uploaded:"       "$(bytes_to_human "$TX")"
        printf "  %-18s %s\n" "Session total:"  "$(bytes_to_human "$TOTAL")"
        if [ "${LIMIT_BYTES:-0}" -gt 0 ]; then
            printf "  %-18s %s%%\n" "Usage:" \
                "$(echo "scale=1; $TOTAL*100/$LIMIT_BYTES" | bc)"
        fi
    else
        printf "  %-18s %s\n" "Last handshake:" "never"
    fi

    echo ""
    echo "──── Config ────────────────────────────"
    local KEYFILE="/etc/wireguard/keys/${NAME}.key"
    if [ -f "$KEYFILE" ]; then
        local CLIENT_CONF
        CLIENT_CONF=$(client_config "$(cat "$KEYFILE")" "$IP")
        echo "$CLIENT_CONF"
        echo "────────────────────────────────────────"
        print_qr "$CLIENT_CONF"
    else
        echo "(Key missing - run: wg-forge regenerate $NAME)"
        echo "────────────────────────────────────────"
    fi
}

cmd_list() {
    local COUNT
    COUNT=$(grep -vc "^#" "$CLIENTS_FILE" || true)
    echo "╔══════════════════════════════════════════════════════════════════════════════════════╗"
    printf "║  wg-forge Clients (%d total)%55s║\n" "$COUNT" ""
    echo "╚══════════════════════════════════════════════════════════════════════════════════════╝"
    printf "  %-22s %-13s %-10s %-10s %-12s %-12s %s\n" \
        "NAME" "IP" "STATUS" "SESSION" "LIMIT" "LIFETIME" "LAST SEEN"
    echo "  ──────────────────────────────────────────────────────────────────────────────────"

    grep -v "^#" "$CLIENTS_FILE" | while IFS=: read -r NAME PUB IP; do
        local LIM_LINE LIMIT_BYTES STATUS LIFETIME INFO TOTAL_H HS
        LIM_LINE=$(grep "^$NAME:" "$LIMITS_FILE")
        LIMIT_BYTES=$(echo "$LIM_LINE" | cut -d: -f2)
        STATUS=$(echo "$LIM_LINE"      | cut -d: -f4)
        LIFETIME=$(grep "^$NAME:" "$TOTAL_FILE" | cut -d: -f2)
        INFO=$(wg_peer_info "$PUB")

        if [ -n "$INFO" ]; then
            local HS_RAW RX TX
            HS_RAW=$(echo "$INFO" | awk '{print $5}')
            RX=$(echo "$INFO"     | awk '{print $6}')
            TX=$(echo "$INFO"     | awk '{print $7}')
            TOTAL_H=$(bytes_to_human $((RX + TX)))
            HS=$(handshake_age "$HS_RAW")
        else
            TOTAL_H="0B"; HS="never"
        fi

        local LIMIT_H
        LIMIT_H=$([ "${LIMIT_BYTES:-0}" -gt 0 ] \
            && bytes_to_human "$LIMIT_BYTES" || echo "unlimited")

        printf "  %-22s %-13s %-10s %-10s %-12s %-12s %s\n" \
            "$NAME" "${IP%/32}" "${STATUS:-active}" \
            "$TOTAL_H" "$LIMIT_H" \
            "$(bytes_to_human "${LIFETIME:-0}")" "$HS"
    done
}

cmd_disable() {
    local NAME=$1
    [ -z "$NAME" ] && echo "Usage: wg-forge disable <n>" && exit 1
    local LINE PUB
    LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
    [ -z "$LINE" ] && echo "✗ Client '$NAME' not found" && exit 1
    PUB=$(echo "$LINE" | cut -d: -f2)
    wg set "$WG_INTERFACE" peer "$PUB" remove 2>/dev/null
    lim_set_field "$NAME" 4 "disabled"
    # Comment out peer block in wg0.conf so it stays disabled after reboot
    perl -i -0pe "s/(\[Peer\]\n# $NAME\n)/# DISABLED\n# \$1/g" "$WG_CONF"
    echo "✓ Client '$NAME' disabled"
}

cmd_enable() {
    local NAME=$1
    [ -z "$NAME" ] && echo "Usage: wg-forge enable <n>" && exit 1
    local LINE PUB IP
    LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
    [ -z "$LINE" ] && echo "✗ Client '$NAME' not found" && exit 1
    PUB=$(echo "$LINE" | cut -d: -f2)
    IP=$(echo "$LINE"  | cut -d: -f3)
    wg set "$WG_INTERFACE" peer "$PUB" allowed-ips "${IP%/32}/32"
    awk -F: -v n="$NAME" \
        'BEGIN{OFS=":"} $1==n{$3="0";$4="active"} {print}' \
        "$LIMITS_FILE" > /tmp/.wgf_lim && mv /tmp/.wgf_lim "$LIMITS_FILE"
    # Restore peer block in wg0.conf
    perl -i -0pe "s/# DISABLED\n# (\[Peer\]\n# $NAME\n)/\$1/g" "$WG_CONF"
    echo "✓ Client '$NAME' enabled and usage reset"
}

cmd_extend() {
    local NAME=$1 EXTRA=$2
    [ -z "$NAME" ] || [ -z "$EXTRA" ] && \
        echo "Usage: wg-forge extend <n> <amount e.g. 10GB>" && exit 1
    grep -q "^$NAME:" "$CLIENTS_FILE" || { echo "✗ Client '$NAME' not found"; exit 1; }

    local LIM_LINE OLD_LIMIT USED STATUS EXTRA_BYTES NEW_LIMIT
    LIM_LINE=$(grep "^$NAME:" "$LIMITS_FILE")
    OLD_LIMIT=$(echo "$LIM_LINE" | cut -d: -f2)
    USED=$(echo "$LIM_LINE"      | cut -d: -f3)
    STATUS=$(echo "$LIM_LINE"    | cut -d: -f4)
    EXTRA_BYTES=$(human_to_bytes "$EXTRA")
    NEW_LIMIT=$((OLD_LIMIT + EXTRA_BYTES))

    lim_set_field "$NAME" 2 "$NEW_LIMIT"

    if [ "$STATUS" = "disabled" ]; then
        local LINE PUB IP
        LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
        PUB=$(echo "$LINE" | cut -d: -f2)
        IP=$(echo "$LINE"  | cut -d: -f3)
        wg set "$WG_INTERFACE" peer "$PUB" allowed-ips "${IP%/32}/32"
        lim_set_field "$NAME" 4 "active"
        echo "✓ Client '$NAME' extended by $EXTRA and re-enabled"
    else
        echo "✓ Client '$NAME' extended by $EXTRA"
    fi

    printf "  Used:      %s\n" "$(bytes_to_human "${USED:-0}")"
    printf "  New limit: %s\n" "$(bytes_to_human "$NEW_LIMIT")"
}

cmd_setlimit() {
    local NAME=$1 LIMIT=$2
    [ -z "$NAME" ] || [ -z "$LIMIT" ] && \
        echo "Usage: wg-forge setlimit <n> <limit e.g. 10GB>" && exit 1
    grep -q "^$NAME:" "$CLIENTS_FILE" || { echo "✗ Client '$NAME' not found"; exit 1; }
    lim_set_field "$NAME" 2 "$(human_to_bytes "$LIMIT")"
    echo "✓ Limit for '$NAME' set to $LIMIT"
}

cmd_setdns() {
    local DNS=$1
    [ -z "$DNS" ] && echo "Usage: wg-forge setdns <dns e.g. 1.1.1.1 or '1.1.1.1, 1.0.0.1'>" && exit 1
    if grep -q "^WG_DNS=" "$CONFIG_FILE"; then
        sed -i "s|^WG_DNS=.*|WG_DNS=\"$DNS\"|" "$CONFIG_FILE"
    else
        echo "WG_DNS=\"$DNS\"" >> "$CONFIG_FILE"
    fi
    echo "✓ Client DNS set to $DNS"
    echo "  Existing clients keep their old DNS until you re-share their config"
    echo "  (wg-forge show <name>) or regenerate it."
}

# Set the AllowedIPs pushed to clients. This controls split tunneling:
#   0.0.0.0/0          full tunnel (all client traffic via the VPN)
#   10.0.0.0/8         split tunnel (only that subnet via the VPN)
# Multiple routes can be comma-separated, e.g. "10.0.0.0/8, 192.168.1.0/24".
cmd_setroutes() {
    local ROUTES=$1
    [ -z "$ROUTES" ] && \
        echo "Usage: wg-forge setroutes <AllowedIPs e.g. 0.0.0.0/0 or '10.0.0.0/8, 192.168.1.0/24'>" && exit 1
    if grep -q "^WG_ALLOWED_IPS=" "$CONFIG_FILE"; then
        sed -i "s|^WG_ALLOWED_IPS=.*|WG_ALLOWED_IPS=\"$ROUTES\"|" "$CONFIG_FILE"
    else
        echo "WG_ALLOWED_IPS=\"$ROUTES\"" >> "$CONFIG_FILE"
    fi
    echo "✓ Client routes (AllowedIPs) set to $ROUTES"
    echo "  Existing clients keep their old routes until you re-share their config"
    echo "  (wg-forge show <name>) or regenerate it."
}

cmd_regenerate() {
    local NAME=$1
    [ -z "$NAME" ] && echo "Usage: wg-forge regenerate <n>" && exit 1
    local LINE
    LINE=$(grep "^$NAME:" "$CLIENTS_FILE")
    [ -z "$LINE" ] && echo "✗ Client '$NAME' not found" && exit 1

    local OLD_PUB IP PRIV PUB
    OLD_PUB=$(echo "$LINE" | cut -d: -f2)
    IP=$(echo "$LINE"      | cut -d: -f3)
    PRIV=$(wg genkey)
    PUB=$(echo "$PRIV" | wg pubkey)

    printf "%s" "$PRIV" > "/etc/wireguard/keys/${NAME}.key"
    chmod 600 "/etc/wireguard/keys/${NAME}.key"

    wg set "$WG_INTERFACE" peer "$OLD_PUB" remove 2>/dev/null
    wg set "$WG_INTERFACE" peer "$PUB" allowed-ips "${IP%/32}/32"
    sed -i "s/^$NAME:$OLD_PUB:/$NAME:$PUB:/" "$CLIENTS_FILE"
    sed -i "/# $NAME/{n;s/PublicKey = .*/PublicKey = $PUB/}" "$WG_CONF"

    echo "✓ Client '$NAME' regenerated"
    echo ""
    echo "──── New Config ────────────────────────"
    client_config "$PRIV" "$IP"
    echo "────────────────────────────────────────"
}

cmd_checklimits() {
    grep -v "^#" "$CLIENTS_FILE" | while IFS=: read -r NAME PUB IP; do
        local INFO RX TX TOTAL LIM_LINE LIMIT_BYTES LAST STATUS
        INFO=$(wg_peer_info "$PUB")
        [ -z "$INFO" ] && continue

        RX=$(echo "$INFO"    | awk '{print $6}')
        TX=$(echo "$INFO"    | awk '{print $7}')
        TOTAL=$((RX + TX))

        LIM_LINE=$(grep "^$NAME:" "$LIMITS_FILE")
        [ -z "$LIM_LINE" ] && continue
        LIMIT_BYTES=$(echo "$LIM_LINE" | cut -d: -f2)
        LAST=$(echo "$LIM_LINE"        | cut -d: -f3)
        STATUS=$(echo "$LIM_LINE"      | cut -d: -f4)

        # Update session counter
        lim_set_field "$NAME" 3 "$TOTAL"

        # Update lifetime
        grep -q "^$NAME:" "$TOTAL_FILE" || echo "$NAME:0" >> "$TOTAL_FILE"
        if [ "$TOTAL" -gt "${LAST:-0}" ]; then
            local DIFF OLD_L
            DIFF=$((TOTAL - ${LAST:-0}))
            OLD_L=$(grep "^$NAME:" "$TOTAL_FILE" | cut -d: -f2)
            awk -F: -v n="$NAME" -v v="$((OLD_L + DIFF))" \
                'BEGIN{OFS=":"} $1==n{$2=v} {print}' \
                "$TOTAL_FILE" > /tmp/.wgf_tot && mv /tmp/.wgf_tot "$TOTAL_FILE"
        fi

        # Disable if over limit
        if [ "${LIMIT_BYTES:-0}" -gt 0 ] && \
           [ "$TOTAL" -ge "$LIMIT_BYTES" ] && \
           [ "$STATUS" = "active" ]; then
            wg set "$WG_INTERFACE" peer "$PUB" remove 2>/dev/null
            lim_set_field "$NAME" 4 "disabled"
            echo "$(date '+%Y-%m-%d %H:%M:%S') | $NAME disabled - $(bytes_to_human "$TOTAL") used" \
                >> /var/log/wg-forge.log
        fi
    done
}

cmd_total() {
    echo "╔══════════════════════════════════════╗"
    echo "║     wg-forge  Lifetime Bandwidth     ║"
    echo "╚══════════════════════════════════════╝"
    printf "  %-24s %s\n" "NAME" "LIFETIME USED"
    echo "  ────────────────────────────────────"
    grep -v "^#" "$TOTAL_FILE" | while IFS=: read -r NAME BYTES; do
        printf "  %-24s %s\n" "$NAME" "$(bytes_to_human "${BYTES:-0}")"
    done
    echo "  ────────────────────────────────────"
    local GRAND
    GRAND=$(grep -v "^#" "$TOTAL_FILE" | awk -F: '{s+=$2} END{print s+0}')
    printf "  %-24s %s\n" "GRAND TOTAL:" "$(bytes_to_human "$GRAND")"
}

cmd_update() {
    [ "$EUID" -ne 0 ] && echo "✗ Run as root" && exit 1
    local REF=${1:-main}
    local BASE_URL="https://raw.githubusercontent.com/Arsh1a/wg-forge/$REF"

    echo "╔══════════════════════════════╗"
    echo "║     wg-forge  Update         ║"
    echo "╚══════════════════════════════╝"
    echo ""
    # Update systemd units first
    if [ -d /etc/systemd/system ]; then
        echo "Updating systemd units..."
        curl -fsSL "$BASE_URL/wg-forge-tracker.service"         -o /etc/systemd/system/wg-forge-tracker.service
        curl -fsSL "$BASE_URL/wg-forge-checklimits.service"     -o /etc/systemd/system/wg-forge-checklimits.service
        curl -fsSL "$BASE_URL/wg-forge-checklimits.timer"       -o /etc/systemd/system/wg-forge-checklimits.timer
        curl -fsSL "$BASE_URL/wg-forge-web.service"             -o /etc/systemd/system/wg-forge-web.service
        systemctl daemon-reload
        systemctl restart wg-forge-tracker wg-forge-checklimits.timer 2>/dev/null || true
        echo "✓ Systemd units updated"
    fi

    # Update tracker binary
    curl -fsSL "$BASE_URL/wg-forge-tracker" -o /usr/local/bin/wg-forge-tracker
    chmod 755 /usr/local/bin/wg-forge-tracker

    # Update and rebuild web dashboard if it was previously set up
    if [ -f /etc/wg-forge/web.conf ]; then
        echo ""
        echo "Updating web dashboard..."
        local REPO_TMP
        REPO_TMP=$(mktemp -d)
        curl -fsSL "https://api.github.com/repos/Arsh1a/wg-forge/tarball/$REF" -o "$REPO_TMP/repo.tar.gz"
        tar -xzf "$REPO_TMP/repo.tar.gz" -C "$REPO_TMP"
        local EXTRACTED_DIR
        EXTRACTED_DIR=$(find "$REPO_TMP" -mindepth 1 -maxdepth 1 -type d | head -1)
        if [ -n "$EXTRACTED_DIR" ] && [ -d "$EXTRACTED_DIR/web" ]; then
            cd /tmp
            rm -rf /opt/wg-forge-web
            mv "$EXTRACTED_DIR/web" /opt/wg-forge-web
            echo "✓ Web source updated"
        else
            echo "⚠ Web source not found in tarball — skipping web update"
        fi
        rm -rf "$REPO_TMP"

        echo "Installing web dependencies..."
        cd /opt/wg-forge-web && npm install --silent
        echo "Building web dashboard..."
        rm -rf build
        npm run build --silent
        echo "✓ Web dashboard built"

        systemctl restart wg-forge-web
        echo "✓ Web dashboard restarted"
    fi

    # Replace the CLI binary last so bash doesn't read the new file mid-execution
    echo ""
    echo "Updating CLI..."
    curl -fsSL "$BASE_URL/wg-forge" -o /usr/local/bin/wg-forge
    chmod 755 /usr/local/bin/wg-forge

    echo "✓ wg-forge updated successfully"
}

cmd_web() {
    local conf="/etc/wg-forge/web.conf"
    [ ! -f "$conf" ] && echo "✗ Web dashboard is not configured. Run 'wg-forge setup'." && exit 1

    # shellcheck source=/dev/null
    source "$conf"

    local BASE_URL
    if [ -n "$WEB_DOMAIN" ]; then
        BASE_URL="https://$WEB_DOMAIN"
    else
        local PUBLIC_IP
        PUBLIC_IP=$(curl -fsSL --max-time 5 https://api.ipify.org 2>/dev/null || echo "localhost")
        BASE_URL="http://${PUBLIC_IP}:${WEB_PORT}"
    fi

    echo ""
    echo "── Web Dashboard ───────────────────────────"
    echo "  User:    $WEB_USER"
    echo "  Port:    $WEB_PORT"
    if [ -n "$SECRET_PATH" ]; then
        echo "  URL:     ${BASE_URL}/${SECRET_PATH}"
    else
        echo "  URL:     ${BASE_URL}"
        echo "  Secret:  (none configured)"
    fi
    echo "  Status:  $(systemctl is-active wg-forge-web 2>/dev/null || echo 'unknown')"
    echo ""
}

cmd_help() {
    cat <<EOF

  wg-forge $VERSION - WireGuard Client Manager

  Usage: wg-forge <command> [args]

  ── Setup ───────────────────────────────────────
    setup                          Install WireGuard, configure server, bring up interface

  ── Clients ─────────────────────────────────────
    add      <n> [limit]        Create client  (e.g. add john 10GB)
    remove   <n>                Remove client
    show     <n>                Show info + config
    list                           List all clients
    disable  <n>                Revoke access
    enable   <n>                Restore access + reset session
    extend   <n> <amount>       Add bandwidth  (e.g. extend john 5GB)
    setlimit <n> <limit>        Change bandwidth limit
    regenerate <n>              Issue new keypair

  ── Server ──────────────────────────────────────
    setdns   <dns>                 Set DNS pushed to clients (e.g. 1.1.1.1)
    setroutes <AllowedIPs>         Set client routes / split tunnel (e.g. 0.0.0.0/0)

  ── Stats ───────────────────────────────────────
    total                          Lifetime bandwidth per user
    checklimits                    Enforce limits (run by cron)

  ── Other ───────────────────────────────────────
    version                        Show version
    update [version]               Update to latest (or a specific version e.g. v0.2.1)
    web                            Show web dashboard URL, user, and status

EOF
}

# Dispatch
# Guarded so the script can be sourced (e.g. by the bats test suite) to load the
# helper functions without loading config or running a command.

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    if [ "$1" != "setup" ]; then
        if [ ! -f "$CONFIG_FILE" ]; then
            echo "✗ Config not found. Run: wg-forge setup"
            exit 1
        fi
        source "$CONFIG_FILE"
    fi

    case "$1" in
        setup)       cmd_setup                 ;;
        add)         cmd_add         "$2" "$3" ;;
        remove)      cmd_remove      "$2"      ;;
        show)        cmd_show        "$2"      ;;
        list)        cmd_list                  ;;
        disable)     cmd_disable     "$2"      ;;
        enable)      cmd_enable      "$2"      ;;
        extend)      cmd_extend      "$2" "$3" ;;
        setlimit)    cmd_setlimit    "$2" "$3" ;;
        setdns)      cmd_setdns      "$2"      ;;
        setroutes)   cmd_setroutes   "$2"      ;;
        regenerate)  cmd_regenerate  "$2"      ;;
        checklimits) cmd_checklimits           ;;
        total)       cmd_total                 ;;
        version|--version|-v) echo "wg-forge $VERSION" ;;
        update)      cmd_update      "$2"      ;;
        web)         cmd_web                  ;;
        help|--help|-h|"") cmd_help           ;;
        *) echo "Unknown command: $1  (run 'wg-forge help')" && exit 1 ;;
    esac
fi
